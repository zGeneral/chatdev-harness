# Generated output — ALL graph run-output lands here (regenerable; never tracked).
# Each graph builds into out/<graph-name>/ (e.g. out/game_factory, out/factory, out/foundation).
out/

# Python / test caches
**/*.pyc
__pycache__/
.pytest_cache/

# Secrets & local config — NEVER commit (only .env.example is tracked)
.env
.dev.vars
*.secret
secret.txt

# Cloudflare worker local state / deps
cloudflare/**/node_modules/
**/.wrangler/

# Transient memory-node temp dir (chmod 700; created at runtime)
.runtmp/

# Scratch / OS
.DS_Store
*.log
.venv/
