# Copy this file to `.env` (which is gitignored) and fill in the values.
# Everything here is OPTIONAL — the core harness (company/gamedev/data-viz graphs, pytest gates)
# works without any of it. These enable the retrieval-memory node and the Art image node.

# --- Cloudflare retrieval memory ------------------------------------------------------------
# Used by `memory` nodes with backend: cloudflare (graphs/*.yaml).
# Deploy your own copy of the Worker, then put its URL + the auth token here:
#   cd cloudflare/memory-worker
#   wrangler vectorize create chatdev-memory --dimensions 1024 --metric cosine
#   wrangler vectorize create-metadata-index chatdev-memory --property-name namespace --type string
#   wrangler d1 create chatdev-memory           # paste the database_id into wrangler.jsonc
#   wrangler d1 execute chatdev-memory --remote --file schema.sql
#   wrangler secret put AUTH_TOKEN              # choose a strong random token
#   wrangler deploy                             # prints your Worker URL
# (see cloudflare/memory-worker/README.md for the full walkthrough)
MEMORY_URL=https://chatdev-memory.<your-subdomain>.workers.dev
MEMORY_TOKEN=<the AUTH_TOKEN you set with `wrangler secret put AUTH_TOKEN`>

# --- Personal-RAG retrieval (optional, private; for `memory` nodes with backend: personal-rag) --
# tools/rag_search.py queries a personal-rag notebook via its Worker /api/search. By default it
# reads creds from the `personal-rag-bridge` MCP config in ~/.claude.json (owner convenience).
# To point at your own personal-rag instead, set these (otherwise the node degrades to a no-op):
# RAG_API_URL=https://your-personal-rag.workers.dev
# RAG_API_TOKEN=<your personal-rag API token>

# --- Gemini image generation ----------------------------------------------------------------
# Used by graphs/art.yaml via tools/genimage.py. Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=<your-gemini-api-key>
